// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Issues collection - allow read/write for authenticated users
    // For development, you can use 'allow read, write: if true;'
    match /issues/{issueId} {
      allow read, write: if true; // TODO: Change to authenticated users in production
      // Production rule example:
      // allow read, write: if request.auth != null;
    }
  }
}
